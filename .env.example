# Server
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gotravels
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_URL=http://localhost:5173

# Optional seed admin for demo/project presentation
ADMIN_NAME=GoTravels Admin
ADMIN_EMAIL=admin@gotravels.test
ADMIN_PASSWORD=admin123

# Optional AI chatbot. Use either OpenRouter free models or OpenAI.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENAI_API_KEY=

# Optional Stripe Checkout payment gateway
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=inr

# Optional Clerk auth migration support
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
